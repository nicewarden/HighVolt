# Copy this file to .env and fill in your own values. Never commit .env.

# Port the server listens on (same port serves the app to your phone on your LAN)
PORT=4000

# HTTPS port, using a self-signed certificate generated automatically on first run.
# Optional - gives you an encrypted https://<lan-ip>:4443 URL as an alternative to the
# plain HTTP one. Not required for recording (that opens your device's own recorder app).
HTTPS_PORT=4443

# PIN required to log in from any browser on your network (4-8 digits or a short password)
HIGHVOLT_PIN=changeme

# Random long string used to sign the login session cookie. Any random text works.
SESSION_SECRET=change-this-to-a-long-random-string

# Google Gemini API key, used to transcribe uploaded/emailed recordings - free tier,
# no credit card or billing account needed. Get one at https://aistudio.google.com/apikey.
# Recording audio leaves the laptop and goes to Google's servers for this step.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local Ollama model used to summarize a recording's transcript and extract
# to-dos/events afterward (must be pulled with `ollama pull <name>` first). Stays
# fully local/free - unrelated to the Gemini-powered steps above.
OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434

# Google Calendar (upcoming events on the To-Do screen). Easiest option: paste your
# calendar's private "Secret address in iCal format" here (Google Calendar settings ->
# your calendar -> "Integrate calendar"). No app registration needed.
GOOGLE_ICS_URL=

# Outlook / Microsoft 365 Calendar. Easiest option: paste the link from Outlook's
# "Publish a calendar" feature (Settings -> Shared calendars -> Publish a calendar).
MS_ICS_URL=

# Alternative for either calendar: a real OAuth app (more setup, but keeps syncing
# even if you ever revoke/regenerate the secret ICS link). See "Calendar Integrations"
# in README for both options. MS_CLIENT_ID/SECRET also power "Plaud Recordings by
# Email", the Email tab (Mail.Read + Mail.Send), and Teams @mentions (Chat.Read) - one
# Azure app registration covers all of it, see README for exact permissions needed.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Subject text to watch for in the connected Outlook inbox for auto-importing Plaud
# recordings emailed to yourself (matched case-insensitively, needs an audio attachment).
PLAUD_EMAIL_SUBJECT=plaud

# Comma-separated sender names/domains to surface on the Dashboard's Company Mail
# widget (matched case-insensitively against the sender's display name or address).
DASHBOARD_EMAIL_SENDERS=Energy Project Solutions,AKS Engineering and Forestry

# Procore integration (optional) — read-only project schedule & daily logs on the
# Scheduling > Procore tab. Register a free OAuth app at https://developers.procore.com
# (see "Procore Integration" in README). COMPANY_ID / PROJECT_ID are the numeric IDs
# visible in your Procore project's URL.
PROCORE_CLIENT_ID=
PROCORE_CLIENT_SECRET=
PROCORE_COMPANY_ID=
PROCORE_PROJECT_ID=
